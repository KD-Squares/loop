# Loop realtime server — copy to server/.env and fill in.

# Supabase (server-side, privileged). NEVER expose the service role key publicly.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co        # TODO: paste your own value
SUPABASE_SERVICE_ROLE_KEY=YOUR-SUPABASE-SERVICE-ROLE-KEY            # TODO: paste your own value

# Listening port
PORT=4000

# The web app origin allowed to connect (CORS).
WEB_ORIGIN=http://localhost:3000                                    # TODO: paste your own value

# Game tuning
MAX_PLAYERS=100
HOST_GRACE_SECONDS=90
GAME_IDLE_TIMEOUT_SECONDS=1800
