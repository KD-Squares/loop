# Loop web app — copy to web/.env.local and fill in.

# Browser-safe Supabase values
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co        # TODO: paste your own value
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-KEY                 # TODO: paste your own value

# Server-only secrets (used by /api routes — never sent to the browser)
SUPABASE_SERVICE_ROLE_KEY=YOUR-SUPABASE-SERVICE-ROLE-KEY            # TODO: paste your own value
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXX                    # TODO: paste your own key

# Realtime server
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000                        # TODO: paste your own value
# Server-to-server URL the /api/games route uses to launch a game.
# Usually the same host as NEXT_PUBLIC_SOCKET_URL.
SOCKET_SERVER_INTERNAL_URL=http://localhost:4000                    # TODO: paste your own value
