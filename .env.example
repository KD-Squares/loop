# =============================================================================
# Loop — environment variables
# Copy this file:
#   - web side    -> web/.env.local
#   - server side -> server/.env
# Fill in values where marked. NEVER commit real keys.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (project URL + keys)
# Find these in: Supabase Dashboard -> Project Settings -> API
# -----------------------------------------------------------------------------

# Browser-safe. Used by the Next.js client and server.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co        # TODO: paste your own value
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-KEY                 # TODO: paste your own value

# Server ONLY. Privileged full-DB access. NEVER expose to the browser.
# Used by Next.js /api routes and the realtime server.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SUPABASE-SERVICE-ROLE-KEY            # TODO: paste your own value

# -----------------------------------------------------------------------------
# Anthropic (question generation) — server ONLY, never to the browser
# Find this in: https://console.anthropic.com/ -> API Keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=YOUR-ANTHROPIC-API-KEY                    # TODO: paste your own key

# -----------------------------------------------------------------------------
# Realtime server connection
# -----------------------------------------------------------------------------

# Browser-safe. URL the player/host browsers use to reach the Socket.IO server.
# Local dev: http://localhost:4000
# Production: your Railway/Render URL, e.g. https://loop-server.up.railway.app
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000                        # TODO: paste your own value

# -----------------------------------------------------------------------------
# Realtime server tuning (server side only)
# -----------------------------------------------------------------------------
MAX_PLAYERS=100                  # Player cap per game
HOST_GRACE_SECONDS=90            # How long a game pauses for a dropped host before closing
GAME_IDLE_TIMEOUT_SECONDS=1800   # Auto-close a stale, inactive game (30 min)

# Port the realtime server listens on (server side only)
PORT=4000

# CORS: the web app's origin, so the browser can connect to the socket server.
# Local dev: http://localhost:3000  | Production: your Vercel URL
WEB_ORIGIN=http://localhost:3000                                    # TODO: paste your own value
