{
  "name": "loop",
  "version": "1.0.0",
  "private": true,
  "description": "Loop — a real-time, game-based quiz web app (Kahoot-style, deliberately simple).",
  "workspaces": [
    "web",
    "server"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:web dev:server",
    "dev:web": "npm run dev --workspace web",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace web && npm run build --workspace server",
    "start:web": "npm run start --workspace web",
    "start:server": "npm run start --workspace server",
    "lint": "npm run lint --workspace web"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
